# ============================================================
# small p club — Environment Variables
# Kopiere diese Datei zu .env.local und trage deine Keys ein.
# .env.local wird NIEMALS ins Git committed.
# ============================================================

# DeepL Free API — nur lokal für translate script
# Key: deepl.com → Account → API-Zugangsdaten
DEEPL_API_KEY=

# ----- Rate Limiting (Upstash Redis — kostenlos) -----
# Account: upstash.com → Redis Database → REST API
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----- Newsletter (Brevo — EU-Server, Free Tier 300/Tag) -----
# Account: app.brevo.com → Settings → SMTP & API → API Keys
# List-ID findest du in CRM → Listen → Listen-Detail
BREVO_API_KEY=
BREVO_LIST_ID=5
BREVO_SENDER_EMAIL=mit-glied@smallp.club
BREVO_SENDER_NAME=mit-glied

# ----- Auth (Auth.js v5) -----
# AUTH_SECRET muss ein starker Zufallswert sein.
# Generieren mit: openssl rand -base64 32
# AUTH_SECRET=
# AUTH_URL=https://smallp.club   (auf Vercel nicht nötig — wird auto-erkannt)

# ----- Magic Link E-Mails (all-inkl SMTP — DE-Mailserver) -----
# Postfach mit-glied@smallp.club bei all-inkl, SMTP-Daten in Proton Pass
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ----- Datenbank (Supabase) -----
# NEXT_PUBLIC_ Keys sind sicher im Browser (durch RLS geschützt)
# Service Role Key NIEMALS mit NEXT_PUBLIC_ prefix!
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ----- Shop (Shopify — kommt später) -----
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
