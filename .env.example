# ============================================================
# small p club — Environment Variables
# Kopiere diese Datei zu .env.local und trage deine Keys ein.
# .env.local wird NIEMALS ins Git committed.
# ============================================================

# DeepL Free API — nur lokal für translate script
# Key: deepl.com → Account → API-Zugangsdaten
DEEPL_API_KEY=

# ----- Rate Limiting (Upstash Redis — kostenlos) -----
# Account: upstash.com → Redis Database → REST API
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----- Newsletter (Brevo — EU-Server, Free Tier 300/Tag) -----
# Account: app.brevo.com → Settings → SMTP & API → API Keys
# List-ID findest du in CRM → Listen → Listen-Detail
BREVO_API_KEY=
BREVO_LIST_ID=5
BREVO_SENDER_EMAIL=mit-glied@smallp.club
BREVO_SENDER_NAME=mit-glied

# ----- Auth + Datenbank (Supabase Auth direkt, kein Auth.js) -----
# NEXT_PUBLIC_ Keys sind sicher im Browser (durch RLS geschützt).
# Service Role Key NIEMALS mit NEXT_PUBLIC_ prefix!
# Magic-Link-SMTP wird im Supabase-Dashboard konfiguriert
# (Project Settings → Auth → SMTP), nicht hier als Env-Var.
# Siehe supabase/README.md für Setup-Reihenfolge.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ----- Cloudflare Turnstile (Bot-Schutz vor Magic-Link-Form) -----
# Account: dash.cloudflare.com → Turnstile → Site hinzufügen
# Widget-Mode: Managed
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ----- Hash-Pepper (Blocklist-Email/IP + MFA-Backup-Codes) -----
# Serverseitiges Geheimnis für HMAC-Hashing (Security-Audit M2). Verhindert,
# dass gehashte Emails/IPs gegen Kandidatenlisten/Rainbow-Tables matchbar sind.
# Erzeugen: `openssl rand -hex 32`
# WICHTIG: VOR dem ersten Ban setzen und danach NIE ändern — sonst matchen
# bestehende Blocklist-/Backup-Hashes nicht mehr. In Vercel als Sensitive.
# HASH_PEPPER=

# ----- Site-URL (Magic-Link-Redirect-Origin) -----
# NEXT_PUBLIC_SITE_URL=https://smallp.club

# ----- Cloudflare-Echtheits-Stempel (verhindert IP-Spoofing über die rohe Vercel-URL) -----
# Selber Wert wie in der Cloudflare-Transform-Rule (Header x-cf-verify).
# Erzeugen: `openssl rand -hex 32`. Nur setzen NACHDEM die Cloudflare-Regel
# aktiv ist (sonst würde legitimer Traffic den Stempel nicht haben).
# CF_VERIFY_SECRET=

# ----- Shop (Shopify — kommt später) -----
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=
